# AtomAI — Environment Variables
# Copy this file to .env.local and fill in values as needed

# Optional: OpenAI API key for GPT-powered responses (falls back to built-in knowledge base)
# OPENAI_API_KEY=sk-...

# Optional: Anthropic API key for Claude-powered responses
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Local LLM endpoint (Ollama, llama.cpp, etc.)
# LOCAL_LLM_URL=http://localhost:11434/api/generate
# LOCAL_LLM_MODEL=llama3.1
